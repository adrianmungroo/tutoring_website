    </div>
  </footer>

  <script define:vars={{ emailAddress: tutor.email }}>
    const btn = document.getElementById('copy-email-btn');
    const hintEl = btn?.querySelector('.contact-method__hint');
    const valueEl = btn?.querySelector('.contact-method__value');

    btn?.addEventListener('click', async () => {
      if (!hintEl || !valueEl) return;
      try {
        await navigator.clipboard.writeText(emailAddress);
        hintEl.textContent = 'Copied to clipboard';
        btn.classList.add('is-copied');
        window.setTimeout(() => {
          hintEl.textContent = 'Click to copy';
          btn.classList.remove('is-copied');
        }, 2200);
      } catch {
        hintEl.textContent = 'Could not copy — select the address above';
        window.setTimeout(() => {
          hintEl.textContent = 'Click to copy';
        }, 3200);
      }
    });
  </script>

</BaseLayout>
